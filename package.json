{
  "name": "obsidian-day-planner-og",
  "version": "1.0.7",
  "description": "A plugin to help you plan your day and setup pomodoro timers",
  "main": "main.js",
  "scripts": {
    "dev": "node --env-file-if-exists=.env ./esbuild.config.mjs",
    "fix": "npx @biomejs/biome check --write ./src",
    "format": "npx @biomejs/biome format ./src",
    "eslint": "npx eslint",
    "lint": "npx @biomejs/biome lint ./src",
    "prebuild": "npx @biomejs/biome check ./src",
    "build": "vitest --run && node ./esbuild.config.mjs production",
    "test": "vitest",
    "preversion": "vitest --run && npm run build",
    "version": "auto-changelog -p",
    "brat-notes": "run() { auto-changelog --stdout --hide-credit --hide-empty-releases --template .github/changelog.hbs -v $1 --starting-version $1  > release-notes.md; }; run"
  },
  "keywords": [
    "obsidian",
    "obsidian-md",
    "obsidian-plugin",
    "obsidian-md-plugin"
  ],
  "author": "ebullient",
  "repository": "github.com:ebullient/obsidian-day-planner-og",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@testing-library/svelte": "^5.2.8",
    "@tsconfig/svelte": "^5.0.8",
    "@types/chroma-js": "^3.1.1",
    "@types/moment": "^2.13.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/coverage-v8": "^4.1.8",
    "auto-changelog": "^2.5.1",
    "esbuild": "^0.28.1",
    "esbuild-sass-plugin": "^3.7.0",
    "esbuild-svelte": "^0.9.5",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "ignore-styles": "^5.0.1",
    "obsidian": "^1.13.1",
    "svelte": "^5.55.8",
    "tslib": "^2.8.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "chroma-js": "^3.1.2",
    "obsidian-daily-notes-interface": "^0.9.5"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "overrides": {
    "minimatch": "10.2.3",
    "postcss": ">=8.5.10"
  },
  "auto-changelog": {
    "backfillLimit": false,
    "commitLimit": false,
    "ignoreCommitPattern": "(🔖|🔨|🧹|changelog|release|Update README).*",
    "replaceText": {
      "([;.,] [rR]esolves) #\\d+\\.?\\s*$": "$1",
      "([;.,] [Ff]ixes) #\\d+\\.?\\s*$": "$1"
    }
  }
}
